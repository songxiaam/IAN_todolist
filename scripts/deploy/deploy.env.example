# 复制为 deploy.env 并填写（deploy.env 已被 git 忽略）
# cp scripts/deploy/deploy.env.example scripts/deploy/deploy.env

# SSH 目标
DEPLOY_HOST=root@your-server-ip
DEPLOY_PORT=22
# DEPLOY_SSH_KEY=~/.ssh/id_rsa

# root 用户可用: /var/www/todolist
# deploy 用户推荐（绝对路径，最稳妥）:
DEPLOY_PATH=/home/deploy/todolist
# 或: DEPLOY_PATH='~/todolist'

# 应用监听端口（需与 shared/.env 中 PORT 一致）
DEPLOY_APP_PORT=3000

# PM2 进程名
DEPLOY_APP_NAME=todolist
