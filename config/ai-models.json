{
  "_comment": "阿里百炼专用配置。API Key 填在 .env.local 的 DASHSCOPE_API_KEY。控制台：https://bailian.console.aliyun.com",
  "providers": {
    "dashscope": {
      "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "apiKeyEnv": "DASHSCOPE_API_KEY"
    }
  },
  "defaultProvider": "dashscope",
  "capabilities": {
    "subject_detect": {
      "provider": "dashscope",
      "default": "qwen3-vl-flash",
      "_comment": "轻量视觉，快速识别学科（替代已下线的 qwen-vl-plus）"
    },
    "vision_analyze": {
      "provider": "dashscope",
      "default": "qwen3-vl-plus",
      "math": "qwen3-vl-plus",
      "physics": "qwen3-vl-plus",
      "chemistry": "qwen3-vl-plus",
      "biology": "qwen3-vl-plus",
      "chinese": "qwen3-vl-plus",
      "english": "qwen3-vl-plus",
      "science": "qwen3-vl-flash",
      "history": "qwen3-vl-flash",
      "geography": "qwen3-vl-flash",
      "politics": "qwen3-vl-flash",
      "other": "qwen3-vl-plus",
      "_comment": "错题解析：主科用 qwen3-vl-plus，文科/科学用 qwen3-vl-flash（替代 qwen-vl-max / qwen-vl-plus）"
    },
    "generate_similar": {
      "provider": "dashscope",
      "default": "qwen3.7-max",
      "math": "qwen3.7-plus",
      "physics": "qwen3.7-plus",
      "chemistry": "qwen3.7-plus",
      "biology": "qwen3.7-max",
      "chinese": "qwen3.7-max",
      "english": "qwen3.7-max",
      "science": "qwen3.7-max",
      "history": "qwen3.7-max",
      "geography": "qwen3.7-max",
      "politics": "qwen3.7-max",
      "other": "qwen3.7-max",
      "_comment": "数理化用 qwen3.7-plus 推理出题，其余用 qwen3.7-max"
    },
    "handwriting_remove": {
      "provider": "dashscope",
      "default": "disabled",
      "_comment": "去手写为独立图像 API，后续接入"
    }
  }
}
